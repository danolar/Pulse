# Template for NextJS environment variables.

# For local development, copy this file, rename it to .env.local, and fill in the values.
# When deploying live, you'll need to store the vars in Vercel/System config.

# If not set, we provide default values (check `scaffold.config.ts`) so developers can start prototyping out of the box,
# but we recommend getting your own API Keys for Production Apps.

# To access the values stored in this env file you can use: process.env.VARIABLENAME
# You'll need to prefix the variables names with NEXT_PUBLIC_ if you want to access them on the client side.
# More info: https://nextjs.org/docs/pages/building-your-application/configuring/environment-variables
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
NEXT_PUBLIC_WORLD_APP_ID=
NEXT_PUBLIC_WORLD_RP_ID=
# Server-only: RP signing key from Developer Portal (required for real IDKit)
WORLD_RP_SIGNING_KEY=
# staging = IDKit simulator (recommended for dev) · production = real World App on phone
NEXT_PUBLIC_WORLD_ID_ENVIRONMENT=staging
# Verify uses production portal by default (see packages/nextjs/app/api/world-id/verify/route.ts)
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# true = Scaffold-ETH dev UI (floating bar, debug/explorer links, acting-as switcher)
NEXT_PUBLIC_SHOW_SCAFFOLD_DEV_UI=
# Active contract (PulseOracleV2): yarn deploy --tags PulseOracleV2 --network sepolia
NEXT_PUBLIC_PULSE_ORACLE_ADDRESS=
# Legacy v0.1 for comparison only
NEXT_PUBLIC_PULSE_ORACLE_LEGACY_ADDRESS=0xf954586747b7361f9deac0f943160a2d66ec8e5f
# Pulse-hosted internal adapter signers (authorizeAdapter per profile). Dev defaults: Hardhat accounts #0–#2.
NEXT_PUBLIC_PULSE_INTERNAL_ADAPTER_ADDRESS=
NEXT_PUBLIC_PULSE_ONCHAIN_ADAPTER_ADDRESS=
NEXT_PUBLIC_PULSE_GOOGLE_ADAPTER_ADDRESS=
NEXT_PUBLIC_PULSE_VOICE_ADAPTER_ADDRESS=
# Hackathon CRE adapter (Hardhat mnemonic #3) — fund on Sepolia; no private key in Next.js
NEXT_PUBLIC_PULSE_CRE_ADAPTER_ADDRESS=0x90F79bf6EB2c4f870365E785982E1f101E93b906
# Optional server-only override for local API broadcast (prefer: yarn cre:report from repo root)
# CRE_ADAPTER_PRIVATE_KEY=
PULSE_PROFILE_OWNER=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
PULSE_PROFILE_CONSUMER=0x4D7a23045f7C76Dc57e2aFd2eb038e2Cf743e284
PULSE_INACTIVITY_SECONDS=300
PULSE_INACTIVE_WEIGHT=10
# Optional; defaults to Scaffold Etherscan key for faster inactivity lookups
ETHERSCAN_API_KEY=
# Server-side only (upload scripts); testnet publisher needs no wallet
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# Neon Postgres — profile storage (Dashboard → Connection string)
POSTGRES_URL=

