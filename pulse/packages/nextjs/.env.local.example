# Copy to packages/nextjs/.env.local and fill in after World ID Developer Portal registration.
# https://developer.world.org

NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Required for real IDKit (without these, /setup uses mock verification)
NEXT_PUBLIC_WORLD_APP_ID=
NEXT_PUBLIC_WORLD_RP_ID=
