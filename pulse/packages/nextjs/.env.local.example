# Copy to packages/nextjs/.env.local and fill in after World ID Developer Portal registration.
# https://developer.world.org

NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Required for real IDKit (without APP_ID, /setup uses mock verification)
NEXT_PUBLIC_WORLD_APP_ID=
NEXT_PUBLIC_WORLD_RP_ID=
# Server-only — NOT the same as NEXT_PUBLIC_WORLD_RP_ID!
# Developer Portal → Apps → [your app] → Relying Party → "Signing key" (0x + 64 hex chars)
WORLD_RP_SIGNING_KEY=

# --- World ID: two independent settings ---
#
# 1) IDKit widget (client) — use staging for simulator / dev testing:
NEXT_PUBLIC_WORLD_ID_ENVIRONMENT=staging
#
# 2) Verify API (server) — defaults to production portal (developer.world.org)
#    where your app is migrated to World ID 4.0. Do NOT tie this to IDKit staging.
#    Only enable if your app is also migrated on staging-developer.worldcoin.org:
# NEXT_PUBLIC_WORLD_ID_USE_STAGING_VERIFY=true
# WORLD_ID_VERIFY_BASE_URL=https://developer.world.org

# --- App URL (local dev vs production) ---
# PORT=3000
# Dev default: http://localhost:3000  |  Production: https://your-domain.com
APP_BASE_URL=http://localhost:3000

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override — defaults to ${APP_BASE_URL}/api/google/oauth/callback
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=
CRON_SECRET=

# --- Twilio voice check-in (Voice agent module) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Dev: public ngrok URL (yarn tunnel:ngrok). Prod: can omit — falls back to APP_BASE_URL
# TWILIO_WEBHOOK_BASE_URL=
VOICE_CALLS_ENABLED=false
VOICE_MAX_CALLS_PER_DAY=50
# Free ngrok account authtoken — https://dashboard.ngrok.com/get-started/your-authtoken
# Then run: yarn tunnel:ngrok
NGROK_AUTHTOKEN=
# Optional — falls back to GOOGLE_TOKEN_ENCRYPTION_KEY
# VOICE_TOKEN_ENCRYPTION_KEY=
